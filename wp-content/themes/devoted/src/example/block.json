{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "devoted/example",
    "version": "0.1.0",
    "title": "Example (TypeScript)",
    "category": "widgets",
    "icon": "star-filled",
    "description": "A starter custom block, authored in TypeScript. Copy this folder to create new blocks.",
    "textdomain": "devoted",
    "supports": {
        "html": false,
        "anchor": true
    },
    "attributes": {
        "message": {
            "type": "string",
            "default": ""
        }
    },
    "example": {},
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "viewScript": "file:./view.js"
}
